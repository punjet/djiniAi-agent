etection_feature_short_title\":\"AI Category Detection\",\"ai_category_detection_feature_title\":\"AI Category Detection\",\"ai_compose_feature_description\":\"Expand replies, rephrase answers, or change tone using AI.\",\"ai_compose_feature_short_title\":\"AI Compose\",\"ai_compose_feature_title\":\"AI Compose\",\"ai_compose_my_tone_of_voice_feature_description\":\"Rewrites replies in your tone of voice based on your previous responses.\",\"ai_compose_my_tone_of_voice_feature_short_title\":\"AI Compose (my tone of voice)\",\"ai_compose_my_tone_of_voice_feature_title\":\"AI Compose (my tone of voice)\",\"ai_generated_csat_feature_description\":\"FFor the first time ever, you can get CSAT scores across 100% of your customer conversations using AI-generated analysis.\",\"ai_generated_csat_feature_short_title\":\"CX Score\",\"ai_generated_csat_feature_title\":\"CX Score\",\"ai_summarize_feature_description\":\"Summarize conversations in the inbox using AI.\",\"ai_summarize_feature_short_title\":\"AI Summarize\",\"ai_summarize_feature_title\":\"AI Summarize\",\"ai_summarize_workflow_feature_description\":\"Allow teammates to use AI Summarize to summarize conversations in workflows.\",\"ai_summarize_workflow_feature_short_title\":\"AI Summarize (Workflows)\",\"ai_summarize_workflow_feature_title\":\"AI Summarize (Workflows)\",\"ai_topics_feature_description\":\"Automatically categorize all your support conversations into topics and suptopics.\",\"ai_topics_feature_short_title\":\"AI Topics\",\"ai_topics_feature_title\":\"AI Topics\",\"alexandria_unauthorized\":\"You can try sending us a message or logging in at {app_name}\",\"almost_there\":\"Almost there...\",\"also_in_this_conversation\":\"Also in this conversation\",\"amazing\":\"Amazing\",\"animals_nature\":\"Animals & Nature\",\"answer\":\"Answer\",\"answer_inspection_feature_description\":\"See the sources and settings that shape Fin\\'s responses.\",\"answer_inspection_feature_short_title\":\"Answer inspection\",\"answer_inspection_feature_title\":\"Answer inspection\",\"answer_is_generated_with_ai\":\"This answer is based only on content specified by {company_name}. It is AI generated so may not be fully correct.\",\"answer_is_generated_with_ai_may_be_incorrect\":\"This answer was auto generated using AI. There’s a chance it may not be fully correct.\",\"answer_is_generated_with_ai_sources\":\"AI answers are generated based on both public and private sources provided by {company_name}.\",\"answer_length_feature_description\":\"You can choose how long Fin\\'s answers are, from shorter and concise, to longer and more thorough.\",\"answer_length_feature_short_title\":\"Answer length\",\"answer_length_feature_title\":\"Answer length\",\"answer_rating_feature_description\":\"Review and rate each of Fin\\'s answers.\",\"answer_rating_feature_short_title\":\"Answer rating\",\"answer_rating_feature_title\":\"Answer rating\",\"app_permissions_feature_description\":\"Set permissions for who can install, configure, and delete apps.\",\"app_permissions_feature_short_title\":\"App permissions\",\"app_permissions_feature_title\":\"App permissions\",\"april_date\":\"April {date}\",\"article\":\"article\",\"article_double_author\":\"By {author_first_name1} and {author_first_name2}\",\"article_multiple_authors\":\"By {author_first_name1} and {number_of_other_authors} others\",\"article_question\":\"Did this answer your question?\",\"article_search_hint_text\":\"Search articles...\",\"article_search_no_results_for_query\":\"No results for \\\\\"{query}\\\\\"\",\"article_search_search_results\":\"Search results\",\"article_search_search_results_for_query\":\"Search results for \\\\\"{query}\\\\\"\",\"article_single_author\":\"By {author_first_name}\",\"ask_a_question\":\"Ask a question\",\"ask_a_question_placeholder\":\"Ask a question…\",\"ask_a_question_with_ellipsis\":\"Ask a question...\",\"ask_another_question_with_ellipsis\":\"Ask another question...\",\"ask_anything_placeholder\":\"Ask 