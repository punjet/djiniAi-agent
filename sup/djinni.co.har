\":\"Bot\",\"bot_answers_instantly\":\"Bot answers instantly\",\"bot_expectation_text\":\"Our bot can answer many common questions\",\"bot_is_still_thinking\":\"Bot is still thinking...\",\"bot_is_thinking\":\"Bot is thinking...\",\"browse_collections\":\"Browse collections\",\"bulk_whatsapp_feature_description\":\"WhatsApp conversations sent via the Outbound section or series, regardless of audience size.\",\"bulk_whatsapp_feature_short_title\":\"WhatsApp\",\"bulk_whatsapp_feature_title\":\"Bulk WhatsApp\",\"by_email\":\"By email\",\"by_web_notification\":\"By web notification\",\"calendar_back\":\"Back\",\"calendar_booking_confirmed\":\"Booking confirmed\",\"calendar_booking_failed_retry\":\"Booking failed - Retry\",\"calendar_confirm_booking\":\"Confirm booking\",\"calendar_expired\":\"Calendar expired\",\"calendar_next_month\":\"Next month\",\"calendar_no_date_selected\":\"No date selected\",\"calendar_please_try_again\":\"Please try again.\",\"calendar_previous_month\":\"Previous month\",\"calendar_select_date\":\"Select a date\",\"calendar_something_went_wrong\":\"Something went wrong\",\"calendar_try_again\":\"Please try again.\",\"call_barging_feature_description\":\"Managers can jump in during a call to help out with customer requests.\",\"call_barging_feature_short_title\":\"Call barging\",\"call_barging_feature_title\":\"Call barging\",\"call_csat_feature_description\":\"Capture customer satisfaction ratings after the call ends.\",\"call_csat_feature_short_title\":\"Call CSAT\",\"call_csat_feature_title\":\"Call CSAT\",\"call_live_monitoring_feature_description\":\"Managers can listen in during a call and coach agents.\",\"call_live_monitoring_feature_short_title\":\"Call live monitoring\",\"call_live_monitoring_feature_title\":\"Call live monitoring\",\"call_overflow_feature_description\":\"Route calls to a secondary team or configure one of our call deflection options.\",\"call_overflow_feature_short_title\":\"Call overflow\",\"call_overflow_feature_tit