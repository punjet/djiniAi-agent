            "text": "\n\n  \n    <div class=\"mt-3 mb-3 card border rounded-sm p-3\">\n      <h3 class=\"mb-2 ms-3 text-gray-700 font-weight-500\">Схожі вакансії</h3>\n\n      <div class=\"mb-3\">\n        \n          \n          \n  \n  <a href=\"/jobs/833592-ml-engineer/?ref=similar_jobs&amp;from=similar_jobs5&amp;similar_to=834173\" class=\"similar-card d-flex flex-column gap-1 text-reset text-decoration-none\">\n    \n  <header class=\"row gx-2 align-items-start\">\n    \n      <div class=\"col-auto\">\n        \n\n\n\n\n  \n\n\n<div\n  id=\"\"\n  class=\"userpic-wrapper userpic-color_0 userpic_sm_3   userpic--logo\"\n  data-initials=\"V\"\n  style=\"--userpic-bg: var(--userpic-color-0)\"\n>\n  \n</div>\n\n      </div>\n    \n    <div class=\"col\">\n      <h2 class=\"job-item__position fs-4 m-0 mb-1\">ML Engineer</h2>\n      <div class=\"d-flex flex-wrap align-items-center column-gap-1\">\n        <span class=\"small text-gray-800 opacity-75 font-weight-500\">Vidar Systems</span>\n        <span class=\"d-flex flex-wrap align-items-center column-gap-2\"><span class=\"text-primary\" data-bs-toggle=\"tooltip\" title=\"Компанія має підтверджені найми\">\n    \n  <svg class=\"bi bi-svg \" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/bootstrap-icons.svg#patch-check-fill\"></use></svg>\n\n  </span></span>\n      </div>\n    </div>\n    <div class=\"col-auto\">\n      <div class=\"fs-5\">\n        \n          \n  \n    <span class=\"text-body-tertiary fw-medium\"\n      data-bs-toggle=\"tooltip\" \n      title=\"Рівень зарплати відносно інших вакансій: $ — нижче середнього, $$ — середній, $$$ — вище середнього, $$$$ — найвищий\"\n    >$$$</span>\n  \n\n        \n      </div>\n    </div>\n  </header>\n\n\n    \n      <div class=\"text-secondary\">\n        \n  \n  <div id=\"job-description-833592\">\n    \n      <p class=\"fs-5 mb-0\" \n        \n          style=\"\n          display: -webkit-box;\n          -webkit-box-orient: vertical;\n         