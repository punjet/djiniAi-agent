close me-2 ms-auto js-candidate-notification-close\"\n        aria-label=\"Close\"\n      ></button>\n    </div>\n  </div>\n\n\n      <div class=\"page-content\">\n        \n  <div class=\"container job-post-page\">\n    \n    <div class=\"d-md-none mb-3\">\n      <a\n        \n        href=\"djinni://(tabs)/jobs/834173\"\n        class=\"btn btn-dark w-100 fw-medium open-in-app-btn d-flex align-items-center justify-content-center gap-2\"\n        data-job-id=\"834173\"\n        data-candidate-id=\"985442\"\n      >\n        <span class=\"open-in-app-icon d-inline-flex align-items-center\"></span>\n        Відкрити в застосунку Djinni\n      </a>\n    </div>\n\n    <header class=\"mb-3\">\n      \n\t\n\t\t<ol class=\"breadcrumb\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n\t\t\t\n\t\t\t\t\n\t\t\t    <li class=\"breadcrumb-item\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n\t\t\t      <a itemprop=\"item\" href=\"/jobs/\">\n\t\t\t        <span itemprop=\"name\">Всі вакансії</span>\n\t\t\t      </a>\n\t\t\t      <meta itemprop=\"position\" content=\"1\" />\n\t\t\t    </li>\n\t\t\t\t\n\t\t  \n\t\t\t\t\n\t\t\t    <li class=\"breadcrumb-item\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n\t\t\t      <a itemprop=\"item\" href=\"/jobs/keyword-data_analytics\">\n\t\t\t        <span itemprop=\"name\">Data and Analytics</span>\n\t\t\t      </a>\n\t\t\t      <meta itemprop=\"position\" content=\"2\" />\n\t\t\t    </li>\n\t\t\t\t\n\t\t  \n\t\t\t\t\n\t\t\t    <li class=\"breadcrumb-item\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n\t\t\t      <a itemprop=\"item\" href=\"/jobs/keyword-data_science\">\n\t\t\t        <span itemprop=\"name\">Data Science</span>\n\t\t\t      </a>\n\t\t\t      <meta itemprop=\"position\" content=\"3\" />\n\t\t\t    </li>\n\t\t\t\t\n\t\t  \n\t\t\t\t\n\t\t\t    <li class=\"breadcrumb-item\" itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\">\n\t\t\t      <a itemprop=\"item\" href=\"/jobs/keyword-ml_ai\">\n\t\t\t        <span itemprop=\"name\">ML / AI</span>\n\t\t\t      </a>\n\t\t\t      <meta itemprop=\"position\" content=\"4\" />\n\t\t\t    </li>\n\t\t\t\t\n\t\t  \n\t\t</ol>\n\t\n\n\n      <div class=\"row align-items-start fs-5 row-gap-3\">\n        \n          <div class=\"col-sm-auto\">\n            <a\n              href=\"/jobs/company-real-estate-bees/\"\n              class=\"picture\"\n              \n            >\n              <div class=\"recruiter-images-container\">\n                \n\n\n\n\n  \n\n\n<div\n  id=\"\"\n  class=\"userpic-wrapper userpic-color_5 userpic_md_2  userpic-transparent is-company-logo userpic--logo\"\n  data-initials=\"R\"\n  style=\"--userpic-bg: var(--userpic-color-5)\"\n>\n  \n    <img\n      class=\"userpic-image userpic-image_img\"\n      src=\"https://p.djinni.co/c4/dd1e527973c4c6bda385df629c87de/images_400.png\"\n      loading=\"lazy\"\n      alt=\"\"\n      onerror=\"this.classList.add('d-none')\"\n      itemprop=\"image\"\n    />\n  \n</div>\n\n              </div>\n            </a>\n          </div>\n        \n\n        <div class=\"col-sm\">\n          <div class=\"row\">\n            <div class=\"col\">\n              <h1 class=\"m-0 mb-1 fs-2\">\n                AI Automation Engineer\n                \n              </h1>\n              <div>\n                <div class=\"d-flex flex-wrap align-items-center column-gap-1\">\n                   <a\n                    href=\"https://djinni.co/jobs/company-real-estate-bees/\"\n                    class=\"text-secondary fw-medium\"\n                  >\n                    Real Estate Bees\n                  </a>\n                  <span class=\"d-flex flex-wrap align-items-center column-gap-2\"><span class=\"text-primary\" data-bs-toggle=\"tooltip\" title=\"Компанія має підтверджені найми\">\n    \n  <svg class=\"bi bi-svg \" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/bootstrap-icons.svg#patch-check-fill\"></use></svg>\n\n  </span>\n          <span class=\"badge badge-outline-gold\" data-bs-toggle=\"tooltip\" title=\"Відповідає на 100% повідомлень протягом 24 годин\">\n        \n  <svg class=\"bi bi-svg \" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/bootstrap-icons.svg#lightning-charge-fill\"></use></svg>\n Швидко Відповідає\n      </span>\n        </span>\n                </div>\n                \n                  <div class=\"d-flex column-gap-2 mt-1\">\n                    \n                    \n                      <div >\n                        \n  <a\n    href=\"/ajax/jobs_subs/company_subscribe/?job_id=834173\"\n    role=\"button\"\n    hx-post=\"/ajax/jobs_subs/company_subscribe/?job_id=834173\"\n    hx-swap=\"outerHTML\"\n  >\n    \n  <svg class=\"dj-ic dj-ic-bell \" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/dj-icons-sprite.svg#dj-bell\"></use></svg>\n\n    Підписатись\n  </a>\n\n                      </div>\n                    \n                    <div>\n                      \n  \n\n  <a class=\"d-inline-flex align-items-center gap-1 text-body\"\n    hx-post=\"/api/jobs/favorites/?macro=save_job\"\n      hx-vals='{ \"job_id\": 834173, \"referral\": \"detail\" }'\n    hx-swap=\"outerHTML\"\n    href=\"#\"\n    role=\"button\"\n  >\n    \n      \n  <svg class=\"dj-ic dj-ic-bookmark \" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/dj-icons-sprite.svg#dj-bookmark\"></use></svg>\n Зберегти\n  </a>\n\n                    </div>\n                    <div>\n                      \n  \n    <a href=\"#\" hx-post=\"/api/jobs/blocked/834173/?macro=hide_job\" hx-swap=\"outerHTML\" role=\"button\" class=\"icon-link text-body\">\n      <span>\n  <svg class=\"dj-ic dj-ic-minus-circle \" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/dj-icons-sprite.svg#dj-minus-circle\"></use></svg>\n Сховати</span>\n    </a>\n  \n\n                    </div>\n                  </div>\n                \n              </div>\n            </div>\n            <div class=\"col-auto\">\n              <div class=\"fs-3 fw-bold\">\n                \n                  \n  \n    <span class=\"text-body-tertiary fw-medium\"\n      data-bs-toggle=\"tooltip\" \n      title=\"Рівень зарплати відносно інших вакансій: $ — нижче середнього, $$ — середній, $$$ — вище середнього, $$$$ — найвищий\"\n    >$$$$</span>\n  \n\n                \n              </div>\n            </div>\n            \n\n          </div>\n        </div>\n\n        \n      </div>\n\n      <div class=\"mt-2\">\n        \n  \n\n  \n\n  \n\n      </div>\n\n        \n\n    </header>\n\n    \n  <div class=\"mb-3\">\n    <div class=\"card card-body\">\n      <div class=\"row gx-2\">\n        <div class=\"col-auto\">\n          \n  <svg class=\"bi bi-svg text-primary\" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/bootstrap-icons.svg#chat-text-fill\"></use></svg>\n\n        </div>\n        <div class=\"col\">\n          \n            Ви вже відгукнулись на цю вакансію.\n          \n\n          \n            <a href=\"/my/inbox/26030370/\" target=\"_blank\">\n              Відкрити діалог &rarr;\n            </a>\n          \n        </div>\n      </div>\n    </div>\n  </div>\n\n\n    <div class=\"row\">\n      <div class=\"col-lg-8 order-lg-0 order-1\">\n        \n          <div class=\"mb-4 job-post__description\">\n            <p>We are looking for a hands-on <strong>AI Automation Engineer</strong> to own, build, and optimize our entire marketing automation, lead routing, and Voice AI ecosystem.This is <strong>not</strong> a traditional software engineering role requiring complex coding from scratch. Instead, we need a technical builder who masterfully connects systems, designs bulletproof workflows, and leverages AI platforms to drive revenue and protect our lead quality.</p><p>&nbsp;</p><p><strong>What ownership means here</strong></p><p>You own the GoHighLevel direction outright. You decide what to automate, how to structure workflows, which integrations to build, and in what order — then you build them. You're accountable for whether automations actually run, leads actually route, and the system actually scales. When something breaks, you fix it or escalate with a fix already in motion. We won't hand you a ticket queue, and we won't check your hours. We look at whether the system works and continues to improve.</p><p>&nbsp;</p><p><strong>What you'll own</strong></p><p>• <strong>The GHL Ecosystem:</strong> Full end-to-end ownership of our entire GoHighLevel environment.<br>• <strong>Lead Verification Workflows:</strong> Designing strict quality gates to catch bad leads before they trigger refunds.<br>• <strong>Financial Impact:</strong> Direct visibility into and influence over refund rates and revenue attribution.<br>• <strong>Omnichannel Automation:</strong> Crafting workflows, automations, and customer journeys across all brands.<br>• <strong>Voice AI Agents:</strong> Configuring and optimizing conversational flows using platforms like Vapi, Bland, or Retell.<br>• <strong>System Integrations:</strong> Building and maintaining webhooks, API integrations, and third-party connections.<br>• <strong>Stack Optimization:</strong> Deciding which tools GHL should absorb and confidently retiring the rest.</p><p>&nbsp;</p><p><strong>What we are looking for</strong></p><ul><li><strong>HighLevel Mastery:</strong> Deep, hands-on experience with GoHighLevel (or equivalent platforms like ActiveCampaign).</li><li><strong>Voice AI Configuration:</strong> Experience setting up and fine-tuning conversational AI platforms (Vapi, Bland, Retell, etc.).</li><li><strong>Integration Expertise:</strong> Strong skills with Make.com, Zapier, or basic custom code for API webhooks and data routing.</li><li><strong>Data &amp; Logic Driven:</strong> Ability to map out complex lead routing logic and ensure seamless data synchronization.</li><li><strong>Compliance-Aware:</strong> A solid understanding of compliance (TCPA, GDPR, carrier guidelines) at a practical \"don't break the rules\" level.</li></ul><p>&nbsp;</p><p><strong>What you get</strong></p><p>• <strong>Direct Impact:</strong> Visible, measurable impact on revenue—not abstract contributions.<br>• <strong>No Bureaucracy:</strong> Work with a team that ships fast, values execution, and skips corporate red tape.<br>• <strong>Leadership Alignment:</strong> A direct line to leadership with full visibility into business metrics.</p>\n          </div>\n        \n\n        \n\n        \n\n        \n          <div class=\"mb-4\">\n            \n            \n            \n            <div>\n              <h2 class=\"fs-4\">Вимоги до володіння мовами</h2>\n              <div class=\"mb-3\">\n                \n                  <div class=\"mb-2\">\n  \n  \n  \n  \n  <span class=\"csc csc--language csc--readonly csc--compact\">\n    \n      <span class=\"csc__icon\">\n  <svg class=\"bi bi-svg \" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/bootstrap-icons.svg#translate\"></use></svg>\n</span>\n    \n    <span class=\"csc__primary\">Англійська</span>\n    \n      <span class=\"csc__divider\" aria-hidden=\"true\"></span>\n      <span class=\"csc__secondary\">B2 – Вище середнього</span>\n    \n    \n  </span>\n</div>\n                \n                  <div class=\"mb-2\">\n  \n  \n  \n  \n  <span class=\"csc csc--language csc--readonly csc--compact\">\n    \n      <span class=\"csc__icon\">\n  <svg class=\"bi bi-svg \" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/bootstrap-icons.svg#translate\"></use></svg>\n</span>\n    \n    <span class=\"csc__primary\">Українська</span>\n    \n      <span class=\"csc__divider\" aria-hidden=\"true\"></span>\n      <span class=\"csc__secondary\">Носій мови</span>\n    \n    \n  </span>\n</div>\n                \n              </div>\n              \n            </div>\n          </div>\n        \n\n        \n          <div class=\"mb-4\">\n            <div class=\"row gx-2 text-secondary fs-5\">\n              <div class=\"col-auto\">\n  <svg class=\"bi bi-svg text-secondary mr-1\" aria-hidden=\"true\" focusable=\"false\"><use href=\"/static/icons/bootstrap-icons.svg#tags\"></use></svg>\n</div>\n              <div class=\"col\">GoHighLevel, AI Agents, API, Voice AI Agent</div>\n            </div>\n          </div>\n        \n\n        \n\n        \n          <div class=\"mb-4\">\n            \n  \n  \n    \n    \n    \n  \n\n  \n  \n  <div class=\"ck-editor-text\">\n    <h4>Про компанію Real Estate Bees</h4>\n\n    \n      <p>Real Estate Bees is a fast-growing U.S.-based real estate lead marketplace connecting motivated home sellers with investors across the United States.</p><p>We generate high-intent seller leads through SEO, PPC, YouTube, and social media, and deliver them to investors who are actively looking to buy.</p><p>&nbsp;</p><p>We operate as a fully remote, execution-driven startup with a strong focus on scalable acquisition systems, partnerships, and performance marketing infrastructure. Speed of execution and real business impact matter more than theory — we prioritize action over overthinking and move fast on what drives revenue.</p><p>&nbsp;</p><p>Our core values are simple and strict:</p><ul><li>Radical open feedback — we say problems directly and fix them fast</li><li>Ownership — every team member fully owns their processes and outcomes</li><li>Execution-first mindset — results matter more than ideas (80% execution, 20% planning)</li><li>Revenue priority — we focus on what drives more money and real business impact</li><li>Self-education — everyone is expected to continuously learn and improve without waiting for instructions<br>&nbsp;</li></ul><p>We are building a team of high-performance operators — people who move fast, take responsibility, and think like owners. The opportunity is significant, and so is the expectation.<br>&nbsp;</p><p>This is not a traditional corporate environment. It’s a high-growth startup where output defines trajectory.</p>\n      <br>\n    \n    \n    \n      <a\n        href=\"/jobs/company-real-estate-bees/\"\n        class=\"btn btn-outline-secondary my-3 js-analytics-event\"\n        data-analytics=\"company_page\"\n        data-recruiter-id=\"201965\"\n        data-json-parameter='{ \"action\": \"view_page_button_click\" }'\n      >\n        Сторінка компанії\n      </a>\n      \n\n    \n      <br>\n      <strong>Сайт компанії:</strong><br>\n      <a href=\"https://realestatebees.com/\" target=\"_blank\">\n      https://realestatebees.com/</a><br>\n    \n\n    \n\n    \n\n  </div>\n  \n\n          </div>\n        \n\n        \n          <div class=\"mb-4\">\n            \n\n\n<div id=\"job-publication-info\">\n  <div class=\"mb-1\">\n    <div>\n      <span class=\"font-weight-500\">Опубліковано 26 червня</span>\n      \n    </div>\n    <div class=\"fs-5\">\n      <div class=\"d-flex align-items-center mb-1\">\n        <div>\n          70 переглядів\n        </div>\n        <div class=\"px-1 text-secondary\"><span class=\"middot\"> · </span></div>\n        <div>\n          8 відгуків\n        </div>\n      </div>\n\n      \n        \n        \n        <div class=\"d-flex flex-wrap column-gap-3\">\n          \n          \n        </div>\n      \n    </div>\n  </div>\n</div>\n          </div>\n\n          \n            <div id=\"applicant_insights\" class=\"mb-4\">\n              <div class=\"card card-body\">\n                <div class=\"row align-items-center g-2\">\n                  <div class=\"col-sm\">\n                    \n                      <div class=\"fw-medium\">Хочете порівняти свій профіль з кандидатами що подаються на цю вакансію? 🧑‍💻</div>\n                    \n                  </div>\n                  <div class=\"col-sm-auto\">\n                    <a\n                      href=\"#\"\n