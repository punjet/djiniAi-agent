ations?\",\"conversations_space_title\":\"Conversations\",\"copilot_multilingual_feature_description\":\"Use Fin AI Copilot in 45 different languages.\",\"copilot_multilingual_feature_short_title\":\"Multilingual\",\"copilot_multilingual_feature_title\":\"Multilingual\",\"copy\":\"Copy\",\"copy_to_clipboard\":\"Copy this code block to your clipboard.\",\"couldnt_load_app\":\"Couldn\\'t load the app.\",\"couldnt_load_apps\":\"Couldn\\'t load apps.\",\"couldnt_load_content\":\"Couldn\\'t load the content\",\"count_more\":\"{count} more\",\"create_a_ticket\":\"Create a ticket\",\"currently_no_help_articles\":\"There’s currently no help articles available.\",\"custom_actions_feature_description\":\"Call external APIs with custom actions.\",\"custom_actions_feature_short_title\":\"Custom actions\",\"custom_actions_feature_title\":\"Custom actions\",\"custom_answers_feature_description\":\"Fin can use human-written answers with embedded rich media like maps, external data, and custom actions to give you complete control over exactly how specific, high priority or critical questions should be answered.\",\"custom_answers_feature_short_title\":\"Custom Answers\",\"custom_answers_feature_title\":\"Custom Answers\",\"custom_call_reports_feature_description\":\"Create custom reports to dive deeper into call volume and performance data.\",\"custom_call_reports_feature_short_title\":\"Custom call reports\",\"custom_call_reports_feature_title\":\"Custom call reports\",\"custom_emojis\":\"Custom emojis\",\"custom_events_feature_description\":\"Track activity and changing data with custom events.\",\"custom_events_feature_short_title\":\"Custom events\",\"custom_events_feature_title\":\"Custom events\",\"custom_objects_feature_description\":\"Bring in business-critical data to power automated workflows.\",\"custom_objects_feature_short_title\":\"Custom objects\",\"custom_objects_feature_title\":\"Custom objects\",\"custom_reports_feature_description\":\"Create custom reports and build charts using our extensive metric library and chart-building tools.\",\"custom_reports_feature_short_title\":\"Advanced custom reports\",\"custom_reports_feature_title\":\"Advanced custom reports\",\"custom_response_delay_0\":\"Typically replies in a few minutes\",\"custom_response_delay_1\":\"Typically replies in a few hours\",\"custom_response_delay_2\":\"Typically replies in a day\",\"custom_response_delay_3\":\"Typically replies in a week\",\"custom_response_delay_unknown\":\"Will reply as soon as they can.\",\"custom_roles_feature_description\":\"Create custom roles to assign consistent permissions to your team.\",\"custom_roles_feature_short_title\":\"Custom roles\",\"custom_roles_feature_title\":\"Custom roles\",\"customizable_charts_feature_description\":\"Customizable charts used to analyze and display data on reports.\",\"customizable_charts_feature_short_title\":\"Customizable charts\",\"customizable_charts_feature_title\":\"Customizable charts\",\"customizable_report_layout_feature_description\":\"Customize your report by resizing visuals and arranging layouts.\",\"customizable_report_layout_feature_short_title\":\"Customizable report layout\",\"customizable_report_layout_feature_title\":\"Customizable report layout\",\"customize_launcher_logo_feature_description\":\"Display your logo on the messenger launcher.\",\"customize_launcher_logo_feature_short_title\":\"Customize launcher logo\",\"customize_launcher_logo_feature_title\":\"Customize launcher logo\",\"customized_greetings_feature_description\":\"Generate greetings with text to speech or upload custom audio for branded or localized messages.\",\"customized_greetings_feature_short_title\":\"Customized greetings\",\"customized_greetings_feature_title\":\"Customized greetings\",\"cx_score_feature_description\":\"An AI-generated metric that scores the customer experience across all of your conversations.\",\"cx_score_feature_short_title\":\"CX Score\",\"cx_score_feature_title\":\"CX Score\",\"data_export_feature_description\":\"Export Intercom data to a data warehouse.\",\"data_export_feature_short_title\":\"Data export\",\"data_export_feature_title\":\"Data export\",\"december_date\":\"December {date}\",\"discovery_launcher\":\"discovery launcher\",\"discovery_mode_entry_text\":\"Need help?\",\"dismiss\":\"Dismiss\",\"dont_show_suggestions\":\"Don’t show suggestions\",\"download_transcript\":\"Download transcript\",\"drag_drop_overlay_subtitle\":\"They\\'ll be added to your conversation\",\"drag_drop_overlay_title\":\"Drop files or images here\",\"effectiveness_report_feature_description\":\"Get insight into your support team\\'s effectiveness and identify inefficiencies.\",\"effectiveness_report_feature_short_title\":\"Effectiveness report\",\"effectiveness_report_feature_title\":\"Effectiveness report\",\"email\":\"Email\",\"email_campaigns_feature_description\":\"Create and send targeted emails to customers.\",\"email_campaigns_feature_short_title\":\"Email campaigns\",\"email_campaigns_feature_title\":\"Email campaigns\",\"emoji_picker\":\"Emoji picker\",\"empty_conversations\":\"Messages from the team will be shown here\",\"empty_suggestion_prompt\":\"No related suggestions\",\"enable_microphone_for_voice_features\":\"Enable microphone access in your browser settings to use voice features.\",\"enter_fullscreen\":\"Enter fullscreen\",\"enter_text_placeholder\":\"Enter text…\",\"enter_your_email\":\"Enter your email\",\"exit_fullscreen\":\"Exit fullscreen\",\"expand_header\":\"Expand header\",\"expanded\":\"Expanded\",\"expanded_mode_disable\":\"Collapse window\",\"expanded_mode_enable\":\"Expand window\",\"expected_response_delay_10800\":\"under 3 hours\",\"expected_response_delay_120\":\"under 2 minutes\",\"expected_response_delay_1200\":\"under 20 minutes\",\"expected_response_delay_14400\":\"under 4 hours\",\"expected_response_delay_172800\":\"2 days\",\"expected_response_delay_180\":\"under 3 minutes\",\"expected_response_delay_1800\":\"under 30 minutes\",\"expected_response_delay_18000\":\"under 5 hours\",\"expected_response_delay_21600\":\"under 6 hours\",\"expected_response_delay_240\":\"under 4 minutes\",\"expected_response_delay_259200\":\"3 days\",\"expected_response_delay_300\":\"under 5 minutes\",\"expected_response_delay_345600\":\"4 days\",\"expected_response_delay_3600\":\"under 1 hour\",\"expected_response_delay_43200\":\"under 12 hours\",\"expected_response_delay_432000\":\"5 days\",\"expected_response_delay_518400\":\"6 days\",\"expected_response_delay_60\":\"under 1 minute\",\"expected_response_delay_600\":\"under 10 minutes\",\"expected_response_delay_604800\":\"under 1 week\",\"expected_response_delay_7200\":\"under 2 hours\",\"expected_response_delay_86400\":\"1 day\",\"expected_response_delay_900\":\"under 15 minutes\",\"export_conversation_data_feature_description\":\"Easily export your conversation and message data to further analyze your team\\'s performance.\",\"export_conversation_data_feature_short_title\":\"Export conversation data\",\"export_conversation_data_feature_title\":\"Export conversation data\",\"extended_api_limit_feature_description\":\"Companies requiring more API volume can extend to 30,000 calls per minute.\",\"extended_api_limit_feature_short_title\":\"Extended API limit\",\"extended_api_limit_feature_title\":\"Extended API limit\",\"external_and_internal_sources_feature_description\":\"Fin AI Copilot connects to external content (articles, public URLs, PDFs) and internal content (articles or syncs with Confluence, Notion, or Guru.)\",\"external_and_internal_sources_feature_short_title\":\"External & internal sources\",\"external_and_internal_sources_feature_title\":\"External & internal sources\",\"extra_labels_count\":\"+ {labels_count} labels\",\"failed_message\":\"Failed message\",\"failed_to_send\":\"Couldn\\'t send\",\"february_date\":\"February {date}\",\"field_is_required\":\"Field {field_name} is required\",\"file\":\"File\",\"file_max_limit\":\"Maximum {limit} files\",\"file_too_big\":\"Can\\'t send files over {limit}MB\",\"file_type_not_allowed\":\"File type is not allowed\",\"fin_feature_description\":\"Fin is the most sophisticated AI agent in customer service, handling all of your frontline support while delivering human-quality service.\",\"fin_feature_short_title\":\"Fin AI Agent\",\"fin_feature_title\":\"Fin AI Agent\",\"fin_guidance_feature_description\":\"Fin can learn your support policies or instructions in natural language, ensuring it always follows the correct processes with customers.\",\"fin_guidance_feature_short_title\":\"Fin Guidance\",\"fin_guidance_feature_title\":\"Fin Guidance\",\"fin_knowledge_management_feature_description\":\"Fin\\'s industry leading Knowledge Hub makes it easy for your team to control, update and maintain all of the knowledge Fin learns from in a centralized location.\",\"fin_knowledge_management_feature_short_title\":\"Fin Knowledge Management\",\"fin_knowledge_management_feature_title\":\"Fin Knowledge Management\",\"fin_knowledge_sources_feature_description\":\"Fin instantly learns from a variety of public and private knowledge sources, including Help Center articles, internal support content, PDFs, and URLs.\",\"fin_knowledge_sources_feature_short_title\":\"Knowledge sources\",\"fin_knowledge_sources_feature_title\":\"Knowledge sources\",\"fin_multi_source_generative_answers_feature_description\":\"Fin can construct an answer using multiple content sources, enhancing its ability to solve complex questions by using the most relevant information from each source to create a more thorough and comprehensive response.\",\"fin_multi_source_generative_answers_feature_short_title\":\"Multi-Source Generative Answers\",\"fin_multi_source_generative_answers_feature_title\":\"Multi-Source Generative Answers\",\"fin_multilingual_feature_description\":\"Fin can automatically detect and resolve issues in more than 45 languages, giving you complete control over which of those languages you would like to support.\",\"fin_multilingual_feature_short_title\":\"Multilingual\",\"fin_multilingual_feature_title\":\"Multilingual\",\"fin_over_api_feature_description\":\"Integrate Fin almost anywhere using an API connection.\",\"fin_over_api_feature_short_title\":\"Fin over API\",\"fin_over_api_feature_title\":\"Fin over API\",\"fin_over_email_feature_description\":\"Fin can respond to customers over email, with responses structured in a way that feels natural to the channel. At the same time, Fin filters out phishing attempts, spam, and other threats.\",\"fin_over_email_feature_short_title\":\"Fin over email\",\"fin_over_email_feature_title\":\"Fin over email\",\"fin_over_slack_feature_description\":\"Deliver instant, accurate answers on Slack.\",\"fin_over_slack_feature_short_title\":\"Fin over Slack\",\"fin_over_slack_feature_title\":\"Fin over Slack\",\"fin_over_social_feature_description\":\"Fin can deliver conversational support across social channels, including Facebook and Instagram.\",\"fin_over_social_feature_short_title\":\"Fin over social\",\"fin_over_social_feature_title\":\"Fin over social\",\"fin_over_whatsapp_and_sms_feature_description\":\"Fin can deliver conversational support across Whatsapp and SMS.\",\"fin_over_whatsapp_and_sms_feature_short_title\":\"Fin over Whatsapp & SMS\",\"fin_over_whatsapp_and_sms_feature_title\":\"Fin over Whatsapp & SMS\",\"fin_over_whatsapp_feature_description\":\"Fin can respond to customers over WhatsApp, with responses structured in a way that feels natural to the channel.\",\"fin_over_whatsapp_feature_short_title\":\"Fin over WhatsApp\",\"fin_over_whatsapp_feature_title\":\"Fin over WhatsApp\",\"fin_preview_feature_description\":\"See how updates to guidance, deployment settings will appear to customers in real time.\",\"fin_preview_feature_short_title\":\"Fin preview\",\"fin_preview_feature_title\":\"Fin preview\",\"fin_preview_handover_message_part_one\":\"At this point, I’d hand the conversation over to a teammate. However this is just a preview. You can control handovers from <a href=\\\\\"{deploy_url}\\\\\" rel=\\\\\"nofollow noopener noreferrer\\\\\" target=\\\\\"_blank\\\\\">Deploy</a>.\",\"fin_preview_handover_message_part_two\":\"To keep going, ask me another question.\",\"fin_procedures_feature_description\":\"Procedures combine the flexibility of natural language with the reliability of deterministic controls, enabling Fin to resolve complex customer queries from start to finish.\",\"fin_procedures_feature_short_title\":\"Fin Procedures\",\"fin_procedures_feature_title\":\"Fin Procedures\",\"fin_vision_feature_description\":\"Fin can read, analyze and understand images — like screenshots, invoices, and error messages.\",\"fin_vision_feature_short_title\":\"Fin Vision\",\"fin_vision_feature_title\":\"Fin Vision\",\"fin_voice_feature_description\":\"Fin Voice is Intercom\\'s AI Agent for phone support.\",\"fin_voice_feature_short_title\":\"Fin Voice\",\"fin_voice_feature_title\":\"Fin Voice\",\"flags\":\"Flags\",\"food_drink\":\"Food & Drink\",\"forward_to_external_number_feature_description\":\"Forward calls to external numbers when out of office or to connect customers with a partner.\",\"forward_to_external_number_feature_short_title\":\"Forward to external number\",\"forward_to_external_number_feature_title\":\"Forward to external number\",\"frequently_used\":\"Frequently used\",\"from_app\":\"from {app_name}\",\"from_name\":\"from {name}\",\"full_page_help_article_title\":\"Help center article\",\"full_page_new_conversation_label\":\"New conversation\",\"full_page_no_conversations_yet\":\"No conversations yet\",\"full_page_resources_section_title\":\"Resources\",\"full_page_welcome_subtitle\":\"Your step-by-step setup guide\",\"full_page_welcome_title\":\"Get started\",\"generating_answer\":\"Generating answer...\",\"get_an_instant_answer\":\"Get an instant answer\",\"get_help\":\"Get help\",\"get_notified\":\"Get notified\",\"get_notified_by_email\":\"Get notified by email\",\"get_responses_by_email\":\"Get replies by email\",\"gif_attribution\":\"via {providername}\",\"gif_picker\":\"Gif picker\",\"gifs_load_error\":\"Couldn\\'t load GIFs\",\"github_integration_feature_description\":\"Sync GitHub issues with your conversations.\",\"github_integration_feature_short_title\":\"GitHub integration\",\"github_integration_feature_title\":\"GitHub integration\",\"go_back\":\"Go back\",\"go_back_to\":\"Go back, {destination}\",\"go_to\":\"Go to {app_name}\",\"great\":\"Great\",\"group_conversation_1_other_participant_count_short\":\"+1 other\",\"group_conversation_multiple_other_participant_count_short\":\"+{other_participant_count} others\",\"group_conversation_multiple_person_also_participating\":\"{other_participant_count} others are also participating\",\"group_conversation_name_also_participating\":\"{participant_name} is also participating\",\"group_conversation_name_and_1_other_also_particiapting\":\"{participant_name} and 1 other are also participating\",\"group_conversation_name_and_multiple_others_also_participating\":\"{participant_name} and {other_participant_count} others are also participating\",\"group_conversation_one_person_also_participating\":\"1 other is also participating\",\"help_center_article\":\"Help Center Article\",\"help_center_customization_feature_description\":\"Customize the visual appearance of your help center to keep it looking on brand.\",\"help_center_customization_feature_short_title\":\"Help center customization\",\"help_center_customization_feature_title\":\"Help center customization\",\"help_space_title\":\"Help\",\"hi_name\":\"Hi {first_name} 👋\",\"hi_there\":\"Hi <imt>first_name | fallback: \\'there\\'</imt> 👋\",\"hide_messenger_feature_description\":\"Choose whether to hide the messenger.\",\"hide_messenger_feature_short_title\":\"Hide messenger\",\"hide_messenger_feature_title\":\"Hide messenger\",\"hipaa_support_feature_description\":\"Intercom is HIPAA compliant.\",\"hipaa_suppo