            "text": "/**\n * Candidate Inbox WebSocket — Leader/Follower Tab Coordination\n *\n * Only one tab (the \"leader\") opens the actual WebSocket connection via\n * the HTMX WS extension. Other tabs receive messages via BroadcastChannel,\n * avoiding N connections per user when multiple inbox tabs are open.\n *\n * The template renders the container div WITHOUT hx-ext or ws-connect.\n * This script adds those attributes only on the elected leader tab,\n * preventing any race condition with HTMX auto-connecting.\n *\n * Fallback: if BroadcastChannel is unavailable, the tab connects directly.\n */\n(function () {\n  \"use strict\";\n\n  var CHANNEL_NAME = \"candidate_inbox_ws\";\n  var HEARTBEAT_INTERVAL_MS = 2000;\n  var LEADER_TIMEOUT_MS = 5000;\n  var NOTIFICATION_DISMISS_MS = 5000;\n\n  // Guard against re-execution on HTMX navigation\n  if (window._candidateInboxWsInitialized) return;\n  window._candidateInboxWsInitialized = true;\n\n  var wsContainer = document.getElementById(\"candidate-inbox-ws\");\n  if (!wsContainer) return;\n\n  var wsUrl = wsContainer.getAttribute(\"data-ws-url\");\n  if (!wsUrl) return;\n\n  var notificationTimer = null;\n\n  // WS analytics helpers\n  function _getThreadIdFromUrl() {\n    var match = window.location.pathname.match(/\\/my\\/inbox\\/(\\d+)\\//);\n    return match ? match[1] : null;\n  }\n\n  function _getCandidateId() {\n    var el = document.getElementById(\"candidate-inbox-ws\");\n    return el ? el.getAttribute(\"data-candidate-id\") : null;\n  }\n\n  function _extractMsgIdFromHtml(html) {\n    var match = html && html.match(/data-msg-id=\"(\\d+)\"/);\n    return match ? match[1] : null;\n  }\n\n  function _trackWsMsg(type, msgId, mtIdOverride) {\n    if (typeof window.trackEvent !== \"function\") return;\n    var mtId = mtIdOverride || _getThreadIdFromUrl();\n    if (!mtId) return;\n    var info = { type: type, mt_id: mtId };\n    if (msgId) info.msg_id = msgId;\n    var payload = { additional_info: info };\n    var candidateId = _getCandidateId();\n    if (candidateId) payload.candidate_id = parseInt(candidateId, 10);\n    window.trackEvent(\"candidate_inbox_ws_message\", payload);\n  }\n\n  // \"New messages\" button helpers for follower tabs\n  var _followerFirstNewMsg = null;\n  var _followerMsgObserver = null;\n\n  function _isNewMsgInView(element, container) {\n    var elRect = element.getBoundingClientRect();\n    var containerRect = container.getBoundingClientRect();\n    return elRect.top < containerRect.bottom && elRect.bottom > containerRect.top;\n  }\n\n  function _showNewMsgBtn() {\n    var btn = document.getElementById(\"new-messages-btn\");\n    if (btn) btn.classList.remove(\"d-none\");\n  }\n\n  function _hideNewMsgBtn() {\n    var btn = document.getElementById(\"new-messages-btn\");\n    if (btn) btn.classList.add(\"d-none\");\n    if (_followerMsgObserver) {\n      _followerMsgObserver.disconnect();\n      _followerMsgObserver = null;\n    }\n    _followerFirstNewMsg = null;\n  }\n\n  function _observeNewMsg(element) {\n    var messagesContainer = document.querySelector(\".messages\");\n    if (!messagesContainer || _followerMsgObserver) return;\n\n    _followerMsgObserver = new IntersectionObserver(function (entries) {\n      if (entries[0].isIntersecting) {\n        _trackWsMsg(\"new_messages_btn_scroll\");\n        _hideNewMsgBtn();\n        _flushPendingMarkRead();\n      }\n    }, { root: messagesContainer, threshold: 0.1 });\n    _followerMsgObserver.observe(element);\n  }\n\n  document.addEventListener(\"click\", function (e) {\n    if (e.target.closest && e.target.closest(\"#new-messages-btn\")) {\n      if (_followerFirstNewMsg) {\n        _followerFirstNewMsg.scrollIntoView({ behavior: \"smooth\" });\n      }\n      _hideNewMsgBtn();\n      _flushPendingMarkRead();\n    }\n  });\n\n  function prepareInboxForThreadInsert(html) {\n    if (!html) return;\n    var temp = document.createElement(\"div\");\n    temp.innerHTML = html;\n    var oobNodes = temp.querySelectorAll(\"[hx-swap-oob]\");\n    for (var i = 0; i < oobNodes.length; i++) {\n      var node = oobNodes[i];\n      var oobValue = node.getAttribute(\"hx-swap-oob\");\n      if (oobValue && oobValue.indexOf(\"afterbegin:#inbox_list\") !== -1) {\n        // Show #inbox_list and hide empty state when it's hidden (empty inbox)\n        var inboxList = document.getElementById(\"inbox_list\");\n        if (inboxList && inboxList.style.display === \"none\") {\n          inboxList.style.display = \"\";\n          var emptyState = document.querySelector(\".js-empty-inbox-state\");\n          if (emptyState) emptyState.style.display = \"none\";\n        }\n\n        // Dedup: remove existing thread item before inserting new one at top\n        var threadId = node.getAttribute(\"data-thread-id\");\n        if (threadId) {\n          var existing = document.getElementById(\"mt-\" + threadId);\n          if (existing) {\n            var wrapper = existing.closest(\".js-thread-item-wrapper\");\n            if (wrapper) wrapper.remove();\n            else existing.remove();\n          }\n        }\n      }\n    }\n  }\n\n  function showWsOfflineIndicator() {\n    var indicator = document.getElementById(\"ws-offline-indicator\");\n    if (indicator) indicator.classList.remove(\"d-none\");\n  }\n\n  function showNotificationPreview() {\n    var dataEl = document.getElementById(\"candidate-notification-data\");\n    if (!dataEl) return;\n\n    var sender = dataEl.getAttribute(\"data-sender\");\n    var preview = dataEl.getAttribute(\"data-preview\");\n    var mtId = dataEl.getAttribute(\"data-mt-id\");\n\n    if (!preview) return;\n\n    if (mtId && window.location.pathname.indexOf(\"/my/inbox/\" + mtId + \"/\") !== -1) {\n      return;\n    }\n\n    var toast = document.querySelector(\".js-candidate-notification\");\n    if (!toast) return;\n\n    var body = toast.querySelector(\".toast-body\");\n    if (!body) return;\n\n    var text = sender ? sender + \": \" + preview : preview;\n    body.textContent = text;\n\n    if (mtId) {\n      var link = document.createElement(\"a\");\n      link.href = \"/my/inbox/\" + mtId + \"/\";\n      link.className = \"text-dark text-decoration-none\";\n      link.textContent = body.textContent;\n      body.textContent = \"\";\n      body.appendChild(link);\n    }\n\n    toast.style.display = \"\";\n    toast.classList.add(\"show\");\n    addNotificationAutoClosing(toast);\n  }\n\n  // Mark-as-read helpers: when candidate is viewing a thread and a new WS\n  // message arrives for that thread, mark it as read once the message is\n  // actually visible in the viewport and the tab is active.\n  var _markReadTimer = null;\n  var _pendingMarkReadMtId = null;\n  var MARK_READ_DEBOUNCE_MS = 300;\n\n  function _applyBadgeSwaps(html) {\n    if (!html) return;\n    var temp = document.createElement(\"div\");\n    temp.innerHTML = html;\n    var nodes = temp.querySelectorAll(\"[hx-swap-oob]\");\n    for (var i = 0; i < nodes.length; i++) {\n      var node = nodes[i];\n      node.removeAttribute(\"hx-swap-oob\");\n      var target = document.getElementById(node.id);\n      if (target) target.replaceWith(node);\n    }\n  }\n\n  function _extractMtIdFromHtml(html) {\n    var match = html.match(/data-mt-id=\"(\\d+)\"/);\n    return match ? match[1] : null;\n  }\n\n  function _setPendingMarkRead(mtId) {\n    if (!mtId) return;\n    var currentThreadId = _getThreadIdFromUrl();\n    if (currentThreadId && mtId === currentThreadId) {\n      _pendingMarkReadMtId = mtId;\n    }\n  }\n\n  function _flushPendingMarkRead() {\n    if (!_pendingMarkReadMtId) return;\n    if (document.visibilityState !== \"visible\") return;\n    _removeInteractionListeners();\n    var mtId = _pendingMarkReadMtId;\n    _pendingMarkReadMtId = null;\n\n    if (_markReadTimer) clearTimeout(_markReadTimer);\n    _markReadTimer = setTimeout(function () {\n      var csrfToken = document.body.getAttribute(\"data-csrf-token\");\n      fetch(\"/htmx/mark_read_silent/\", {\n        method: \"POST\",\n        headers: {\n          \"X-CSRFToken\": csrfToken,\n          \"Content-Type\": \"application/x-www-form-urlencoded\",\n        },\n        body: \"mt_id=\" + mtId,\n        credentials: \"same-origin\",\n      })\n        .then(function (response) {\n          if (response.ok) return response.text();\n        })\n        .then(function (html) {\n          if (html) _applyBadgeSwaps(html);\n        })\n        .catch(function () {});\n    }, MARK_READ_DEBOUNCE_MS);\n  }\n\n  // Wait for user interaction before flushing mark-as-read.\n  // Prevents marking as read when message auto-scrolls into view but\n  // user isn't paying attention (tab open but idle).\n  var _interactionListenerActive = false;\n  var INTERACTION_EVENTS = [\"mousemove\", \"touchstart\", \"scroll\", \"keydown\", \"click\"];\n\n  function _onUserInteraction() {\n    _removeInteractionListeners();\n    _flushPendingMarkRead();\n  }\n\n  function _waitForInteractionThenFlush() {\n    if (_interactionListenerActive) return;\n    _interactionListenerActive = true;\n    for (var i = 0; i < INTERACTION_EVENTS.length; i++) {\n      document.addEventListener(INTERACTION_EVENTS[i], _onUserInteraction, { passive: true });\n    }\n  }\n\n  function _removeInteractionListeners() {\n    if (!_interactionListenerActive) return;\n    _interactionListenerActive = false;\n    for (var i = 0; i < INTERACTION_EVENTS.length; i++) {\n      document.removeEventListener(INTERACTION_EVENTS[i], _onUserInteraction);\n    }\n  }\n\n  // Exposed for candidate_inbox.js (leader tab's visibility triggers)\n  window._djCandidateInboxMarkSeen = _flushPendingMarkRead;\n\n  document.addEventListener(\"visibilitychange\", function () {\n    if (document.visibilityState !== \"visible\" || !_pendingMarkReadMtId) return;\n    var lastMsg = document.querySelector(\".thread-messages-list .thread-message:last-child\");\n    var container = document.querySelector(\".messages\");\n    if (lastMsg && container && _isNewMsgInView(lastMsg, container)) {\n      _waitForInteractionThenFlush();\n    }\n  });\n\n  // Close button handler\n  document.addEventListener(\"click\", function (e) {\n    if (e.target.closest(\".js-candidate-notification-close\")) {\n      var toast = document.querySelector(\".js-candidate-notification\");\n      if (toast) {\n        toast.classList.remove(\"show\");\n        toast.style.display = \"none\";\n      }\n      if (notificationTimer) clearTimeout(notificationTimer);\n      return;\n    }\n    if (e.target.closest(\".js-candidate-notification .toast-body a\")) {\n      var dataEl = document.getElementById(\"candidate-notification-data\");\n      if (!dataEl) return;\n      _trackWsMsg(\n        \"toast_click\",\n        dataEl.getAttribute(\"data-msg-id\"),\n        dataEl.getAttribute(\"data-mt-id\")\n      );\n    }\n  });\n\n  /**\n   * Close any existing WebSocket stored in HTMX's internal data for the\n   * container element.  HTMX stores the socket wrapper at\n   * elt['htmx-internal-data'].webSocket — closing it explicitly is\n   * necessary because simply removing hx-ext / ws-connect attributes does\n   * NOT trigger htmx:beforeCleanupElement (only DOM removal does).\n   */\n  function closeExistingSocket() {\n    var internalData = wsContainer[\"htmx-internal-data\"];\n    if (internalData && internalData.webSocket) {\n      internalData.webSocket.close();\n      internalData.webSocket = null;\n    }\n  }\n\n  /**\n   * Activate HTMX WS extension on the container — opens the connection.\n   * Only called for the leader tab (or fallback single-tab mode).\n   */\n  function activateWsConnection() {\n    closeExistingSocket();\n    wsContainer.setAttribute(\"hx-ext\", \"ws\");\n    wsContainer.setAttribute(\"ws-connect\", wsUrl);\n    if (typeof htmx !== \"undefined\") {\n      htmx.process(wsContainer);\n    }\n  }\n\n  /**\n   * Deactivate HTMX WS extension — closes the connection.\n   */\n  function deactivateWsConnection() {\n    closeExistingSocket();\n    wsContainer.removeAttribute(\"ws-connect\");\n    wsContainer.removeAttribute(\"hx-ext\");\n  }\n\n  // WS error/close events (only fire on the tab that has the connection)\n  wsContainer.addEventListener(\"htmx:wsError\", function () {\n    showWsOfflineIndicator();\n    if (bc) bc.postMessage({ type: \"ws_error\" });\n  });\n\n  wsContainer.addEventListener(\"htmx:wsClose\", function (event) {\n    var code = event.detail && event.detail.event && event.detail.event.code;\n    if (code && code !== 1000 && code !== 1001 && code !== 1005 && code !== 1006) {\n      showWsOfflineIndicator();\n      if (bc) bc.postMessage({ type: \"ws_error\" });\n    }\n  });\n\n  // Leader tab: intercept WS messages to broadcast to followers\n  document.addEventListener(\"htmx:wsAfterMessage\", function (event) {\n    if (isLeader && bc) {\n      bc.postMessage({ type: \"ws_message\", html: event.detail.message });\n    }\n    // Mark thread as read if this is a new message (not an edit),\n    // the candidate is viewing that thread, and the message is visible.\n    // htmx:wsAfterMessage fires AFTER all OOB swaps, so candidate_inbox.js\n    // has already auto-scrolled or shown the \"New messages\" button.\n    var msg = event.detail && event.detail.message;\n    if (msg && msg.indexOf(\"beforeend:.thread-messages-list\") !== -1) {\n      _setPendingMarkRead(_extractMtIdFromHtml(msg));\n      var btn = document.getElementById(\"new-messages-btn\");\n      if (!btn || btn.classList.contains(\"d-none\")) {\n        _waitForInteractionThenFlush();\n      }\n    }\n  });\n\n  function handleJSONMessage(msg) {\n    const messageTypes = Object.freeze({\n      NEW_EMOJI_NOTIFICATION: \"new_emoji_notification\",\n      MESSAGE_EMOJI_UPDATE: \"message_emoji_update\",\n      THREAD_EMOJI_UPDATE: \"thread_emoji_update\",\n    });\n\n    switch (msg.type) {\n      case messageTypes.NEW_EMOJI_NOTIFICATION:\n        showNewEmojiNotification(msg)\n        break;\n      case messageTypes.MESSAGE_EMOJI_UPDATE:\n        updateMessageEmojisBlock(msg);\n        break;\n      case messageTypes.THREAD_EMOJI_UPDATE:\n        updateThreadUnreadEmojisCount(msg);\n        break;\n    }\n\n    function showNewEmojiNotification(msg) {\n      const notificationContainer = document.querySelector(\".js-candidate-notification\");\n      if (!notificationContainer) {\n        return;\n      }\n      notificationContainer.classList.add(\"show\");\n      notificationContainer.style.display = \"\";\n      const notificationBody = notificationContainer.querySelector(\".toast-body\");\n      notificationBody.outerHTML = msg.content;\n      addNotificationAutoClosing(\n        notificationContainer,\n        NOTIFICATION_DISMISS_MS * 2,\n        );\n    }\n\n    function updateMessageEmojisBlock(msg) {\n      const { msgId, content } = msg;\n      const blockContent = document.querySelector(`#reactions_${msgId}`);\n      if (blockContent) {\n        blockContent.outerHTML = content;\n      }\n    }\n\n    function updateThreadUnreadEmojisCount(msg) {\n      const { mtId, content } = msg;\n      const blockId = `#thread_unread_reaction_${mtId}`;\n      const blockContent = document.querySelector(blockId);\n      if (blockContent) {\n        blockContent.innerHTML = content;\n      }\n    }\n  }\n\n  function addNotificationAutoClosing(\n    notificationContainer,\n    closeAfter = NOTIFICATION_DISMISS_MS,\n  ) {\n    notificationTimer && clearTimeout(notificationTimer);\n    notificationTimer = setTimeout(function () {\n      notificationContainer.classList.remove(\"show\");\n      notificationContainer.style.display = \"none\";\n    }, closeAfter);\n  }\n\n  // Leader tab: remove existing thread item before HTMX processes OOB afterbegin swap\n  // to prevent duplicates when an already-visible thread gets a new message.\n  // Also extract msg_id from the raw WS HTML for tracking (before OOB swaps run).\n  document.addEventListener(\"htmx:wsBeforeMessage\", function (event) {\n    var html = event.detail.message, jsonData = null;\n    try {\n      jsonData = JSON.parse(html);\n    } catch (e) {\n      prepareInboxForThreadInsert(html);\n      window._djLastWsMsgId = _extractMsgIdFromHtml(html);\n      return;\n    }\n\n    handleJSONMessage(jsonData);\n    event.preventDefault();\n  });\n\n  // Skip thread-page-specific OOB swaps (message list, reply form tabs/actions)\n  // when the incoming update is for a different thread than the one the\n  // candidate is currently viewing. These fragments carry data-gate-mt-id.\n  // Global swaps (notification data, badges, inbox list) are unaffected.\n  document.addEventListener(\"htmx:oobBeforeSwap\", function (event) {\n    var incomingMtId = _getFragmentGateMtId(event.detail && event.detail.fragment);\n    if (!incomingMtId) return;\n    var currentMtId = _getThreadIdFromUrl();\n    if (currentMtId && incomingMtId !== currentMtId) {\n      event.preventDefault();\n    }\n  });\n\n  function _getFragmentGateMtId(fragment) {\n    if (!fragment) return null;\n    if (fragment.getAttribute) {\n      var own = fragment.getAttribute(\"data-gate-mt-id\");\n      if (own) return own;\n    }\n    if (fragment.querySelector) {\n      var marker = fragment.querySelector(\"[data-gate-mt-id]\");\n      if (marker) return marker.getAttribute(\"data-gate-mt-id\");\n    }\n    return null;\n  }\n\n  // Leader tab: show notification after OOB swap completes\n  document.addEventListener(\"htmx:oobAfterSwap\", function () {\n    showNotificationPreview();\n  });\n\n  // --- BroadcastChannel setup ---\n\n  var bc = typeof BroadcastChannel !== \"undefined\"\n    ? new BroadcastChannel(CHANNEL_NAME) : null;\n\n  // No BroadcastChannel — connect directly (single-tab fallback)\n  if (!bc) {\n    activateWsConnection();\n    return;\n  }\n\n  var tabId = Math.random().toString(36).slice(2) + Date.now().toString(36);\n  var isLeader = false;\n  var heartbeatTimer = null;\n  var leaderCheckTimer = null;\n  var lastLeaderHeartbeat = 0;\n\n  bc.onmessage = function (event) {\n    var data = event.data;\n\n    if (data.type === \"heartbeat\") {\n      lastLeaderHeartbeat = Date.now();\n      if (isLeader && data.tabId !== tabId && data.tabId < tabId) {\n        demote();\n      }\n    } else if (data.type === \"leader_query\") {\n      if (isLeader) {\n        sendHeartbeat();\n      }\n    } else if (data.type === \"ws_message\") {\n      if (!isLeader) {\n        try {\n          handleJSONMessage(JSON.parse(data.html));\n        } catch (e) {\n          processOobSwaps(data.html);\n        }\n      }\n    } else if (data.type === \"ws_error\") {\n      showWsOfflineIndicator();\n    } else if (data.type === \"leader_resigned\") {\n      lastLeaderHeartbeat = 0;\n      setTimeout(function () {\n        tryBecomeLeader();\n      }, 50 + Math.random() * 200);\n    }\n  };\n\n  function tryBecomeLeader() {\n    if (Date.now() - lastLeaderHeartbeat > LEADER_TIMEOUT_MS) {\n      promote();\n    }\n  }\n\n  function promote() {\n    if (isLeader) return;\n    isLeader = true;\n    activateWsConnection();\n    startHeartbeat();\n  }\n\n  function demote() {\n    if (!isLeader) return;\n    isLeader = false;\n    stopHeartbeat();\n    deactivateWsConnection();\n  }\n\n  function startHeartbeat() {\n    stopHeartbeat();\n    sendHeartbeat();\n    heartbeatTimer = setInterval(sendHeartbeat, HEARTBEAT_INTERVAL_MS);\n  }\n\n  function sendHeartbeat() {\n    bc.postMessage({ type: \"heartbeat\", tabId: tabId });\n  }\n\n  function stopHeartbeat() {\n    if (heartbeatTimer) {\n      clearInterval(heartbeatTimer);\n      heartbeatTimer = null;\n    }\n  }\n\n  function startLeaderCheck() {\n    if (leaderCheckTimer) return;\n    leaderCheckTimer = setInterval(function () {\n      if (!isLeader && Date.now() - lastLeaderHeartbeat > LEADER_TIMEOUT_MS) {\n        promote();\n      }\n    }, HEARTBEAT_INTERVAL_MS);\n  }\n\n  /**\n   * Process hx-swap-oob elements from HTML received via BroadcastChannel.\n   * Follower tabs use this instead of HTMX's built-in OOB swap handling.\n   */\n  function processOobSwaps(html) {\n    if (!html) return;\n\n    var temp = document.createElement(\"div\");\n    temp.innerHTML = html;\n    var nodes = temp.querySelectorAll(\"[hx-swap-oob]\");\n    var hasNewMessage = false;\n\n    var currentMtId = _getThreadIdFromUrl();\n    for (var i = 0; i < nodes.length; i++) {\n      var node = nodes[i];\n      var oobValue = node.getAttribute(\"hx-swap-oob\");\n      node.removeAttribute(\"hx-swap-oob\");\n\n      // Skip thread-page-specific swaps for other threads (wrong-thread isolation)\n      var nodeMtId = node.getAttribute(\"data-gate-mt-id\");\n      if (nodeMtId && currentMtId && nodeMtId !== currentMtId) {\n        continue;\n      }\n\n      if (oobValue === \"true\") {\n        var target = document.getElementById(node.id);\n        if (target) {\n          target.replaceWith(node);\n        }\n      } else {\n        var parts = oobValue.split(\":\");\n        var strategy = parts[0];\n        var selector = parts.slice(1).join(\":\");\n        var targetEl = selector ? document.querySelector(selector) : document.getElementById(node.id);\n        if (!targetEl) continue;\n\n\n        // Handle thread insertion into inbox list\n        if (strategy === \"afterbegin\" && selector === \"#inbox_list\") {\n          // Show #inbox_list and hide empty state when it's hidden (empty inbox)\n          if (targetEl.style.display === \"none\") {\n            targetEl.style.display = \"\";\n            var emptyState = document.querySelector(\".js-empty-inbox-state\");\n            if (emptyState) emptyState.style.display = \"none\";\n          }\n\n          // Dedup: remove existing thread item before inserting new one at top\n          var threadId = node.getAttribute(\"data-thread-id\");\n          if (threadId) {\n            var existing = document.getElementById(\"mt-\" + threadId);\n            if (existing) {\n              var wrapper = existing.closest(\".js-thread-item-wrapper\");\n              if (wrapper) wrapper.remove();\n              else existing.remove();\n            }\n          }\n        }\n\n        switch (strategy) {\n          case \"beforeend\":\n            targetEl.appendChild(node);\n            break;\n          case \"afterbegin\":\n            targetEl.insertBefore(node, targetEl.firstChild);\n            break;\n          case \"outerHTML\":\n            targetEl.replaceWith(node);\n            break;\n          case \"innerHTML\":\n            targetEl.innerHTML = node.innerHTML;\n            break;\n          default:\n            targetEl.replaceWith(node);\n        }\n      }\n\n      if (typeof htmx !== \"undefined\") {\n        htmx.process(node);\n      }\n\n      // Reply form tabs updated — if Decline tab was removed while active, switch to Reply\n      if (node.id === \"replyFormTabs\") {\n        var form = document.querySelector(\".js-inbox-reply-form\");\n        var declineTab = node.querySelector('[data-json-parameter*=\"decline\"]');\n        if (form && form.dataset.type === \"decline\" && !declineTab) {\n          var replyTab = node.querySelector(\".form-link\");\n          if (replyTab) replyTab.click();\n        }\n      }\n\n      if (oobValue.indexOf(\"beforeend:.thread-messages-list\") === 0) {\n        hasNewMessage = true;\n        _trackWsMsg(\"received\", _extractMsgIdFromHtml(html));\n        // Remove stale #last markers so getElementById always finds the latest one\n        var container = document.querySelector(\".thread-messages-list\");\n        if (container) {\n          var allLast = container.querySelectorAll(\"#last\");\n          for (var j = 0; j < allLast.length - 1; j++) {\n            allLast[j].remove();\n          }\n        }\n\n        var newMsg = node.querySelector ? node.querySelector(\".thread-message\") : null;\n        var messagesContainer = document.querySelector(\".messages\");\n        if (newMsg && messagesContainer && !_isNewMsgInView(newMsg, messagesContainer)) {\n          if (!_followerFirstNewMsg) {\n            _followerFirstNewMsg = newMsg;\n            _observeNewMsg(newMsg);\n          }\n          _showNewMsgBtn();\n        } else {\n          var lastEl = document.getElementById(\"last\");\n          if (lastEl) {\n            lastEl.scrollIntoView({ behavior: \"smooth\" });\n          }\n          _hideNewMsgBtn();\n        }\n\n        if (typeof $ !== \"undefined\") {\n          var $msgs = $(node).find(\".thread-message-body\");\n          if ($msgs.length) $msgs.linkify();\n        }\n      }\n    }\n\n    showNotificationPreview();\n    if (hasNewMessage) {\n      _setPendingMarkRead(_extractMtIdFromHtml(html));\n      var btn = document.getElementById(\"new-messages-btn\");\n      if (!btn || btn.classList.contains(\"d-none\")) {\n        _waitForInteractionThenFlush();\n      }\n    }\n  }\n\n  // Lifecycle: resign leadership on tab close\n  window.addEventListener(\"beforeunload\", function () {\n    if (isLeader && bc) {\n      bc.postMessage({ type: \"leader_resigned\", tabId: tabId });\n    }\n  });\n\n  // Start: ask if a leader already exists, then wait for a response\n  // before attempting promotion. BroadcastChannel delivery is near-instant,\n  // so 200ms base delay is enough to receive the heartbeat reply.\n  bc.postMessage({ type: \"leader_query\" });\n  setTimeout(function () {\n    tryBecomeLeader();\n    startLeaderCheck();\n  }, 200 + Math.random() * 300);\n})();\n"
          },
